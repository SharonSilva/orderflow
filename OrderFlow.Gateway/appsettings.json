{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "api-orders": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/orders" }
        ]
      },
      "api-inventory": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/inventory" }
        ]
      },
      "api-payments": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/payments" }
        ]
      },
      "openapi-orders": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/openapi/orders.json"
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      "openapi-inventory": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/openapi/inventory.json"
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      "openapi-payments": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/openapi/payments.json"
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      }
    },
    "Clusters": {
      "orders-cluster": {
        "Destinations": {
          "orders-1": { "Address": "https://localhost:7548/" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-1": { "Address": "https://localhost:7549/" }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-1": { "Address": "https://localhost:7550/" }
        }
      }
    }
  }
}
